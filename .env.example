# ─── Kukora · Environment Variables (.env.example) ────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it may contain secrets.

# ─── Server ───────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ─── MongoDB (optional — uses in-memory if not set) ───────────────────────
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/kukora

# ─── CORS ─────────────────────────────────────────────────────────────────
# Required in production if frontend is on a separate domain (e.g. Vercel).
# On Railway with single-service deploy (frontend + backend), leave unset.
# FRONTEND_URL=https://your-app.up.railway.app

# ─── Admin ────────────────────────────────────────────────────────────────
# Protects POST /api/arbitrage/reset. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ADMIN_TOKEN=your_secret_token_here

# ─── Wallet Initial Balances ──────────────────────────────────────────────
# BTC and USDT allocated per exchange at startup.
# Default 1 BTC + $110k USDT per exchange covers ~20 trades before rebalancing.
# WALLET_BTC=1
# WALLET_USDT=110000

# ─── Arbitrage Engine ─────────────────────────────────────────────────────
# TRADE_AMOUNT_BTC: size per arbitrage trade.
# Default: 0.05 BTC — at $100k/BTC a 0.03% net spread yields ~$1.50 net profit.
# TRADE_AMOUNT_BTC=0.05

# FORCE_MAKER_FEES: use maker fees instead of taker fees.
# Lowers break-even Binance→OKX from 0.030% to 0.016%.
# FORCE_MAKER_FEES=false

# ─── Demo Mode ────────────────────────────────────────────────────────────
# DEMO_MODE=true  → injects ONE synthetic 0.40% opportunity when no real viable
#                   opportunity exists. Synthetic ops are marked [DEMO] in UI.
#                   Use during presentations when real-market spreads are flat.
# DEMO_MODE=false → live mode only (default for production).
DEMO_MODE=false

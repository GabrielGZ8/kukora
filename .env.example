# .env.example
# ─── Server ──────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ─── MongoDB (opcional — sin esto usa memoria) ────────────────────────────
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/kukora

# ─── CORS ────────────────────────────────────────────────────────────────
# FRONTEND_URL=https://tu-app.up.railway.app

# ─── Admin ────────────────────────────────────────────────────────────────
# ADMIN_TOKEN protects the POST /api/arbitrage/reset endpoint
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ADMIN_TOKEN=your_secret_token_here

# ─── Wallet Initial Balances ─────────────────────────────────────────────
# BTC and USDT allocated per exchange at startup
# WALLET_BTC=1
# WALLET_USDT=70000

# ─── Arbitrage Engine v4 ──────────────────────────────────────────────────

# TRADE_AMOUNT_BTC: monto por operación de arbitraje.
# Default: 0.01 BTC (era 0.1 BTC — reducido para bajar break-even).
# Con 0.01 BTC a $100k: notional=$1000, fees≈$2, slippage≈$0.
# Break-even Binance→OKX con taker: ~0.030% (vs mercado actual ~0.010-0.030%).
# Sube a 0.1 si el mercado muestra spreads consistentes >0.10%.
# TRADE_AMOUNT_BTC=0.01

# FORCE_MAKER_FEES: usa maker fees en lugar de taker fees.
# Maker fees son ~50-70% más bajos (Binance: 0.075% vs 0.100% taker).
# Break-even Binance→OKX baja de 0.030% a 0.016%.
# Requiere limit orders — no implementado en simulación actual, solo afecta
# el cálculo de P&L. Para activar en demo: FORCE_MAKER_FEES=true
# FORCE_MAKER_FEES=false

# DEMO_MODE: inyecta oportunidades sintéticas con spread 0.40% cuando el
# mercado real no ofrece spreads viables. Útil para demo day y tests de UI.
# Las oportunidades sintéticas están marcadas claramente con synthetic=true.
# NUNCA activar en producción real.
DEMO_MODE=true  # activar para demo day

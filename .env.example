# Kukora — variables de entorno
# Copia este archivo a .env y ajusta lo que necesites:
#   cp .env.example .env
#
# Nada aquí es obligatorio para desarrollo local: el proyecto corre en
# memoria (sin Mongo) y con secretos JWT aleatorios si no se configuran.
# Ver docs/ADR-* para el razonamiento detrás de cada bloque.

# ─── Servidor ────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173
LOG_LEVEL=info
GIT_SHA=

# ─── Persistencia (opcional — sin esto corre en memoria) ────────────────
# MONGODB_URI=mongodb://localhost:27017/kukora
MONGODB_URI=

# ─── Autenticación / JWT ─────────────────────────────────────────────────
# Si se omiten, se generan secretos aleatorios en cada arranque (las
# sesiones no persisten entre reinicios). En producción, server/index.js
# falla duro si faltan — nunca hay un fallback silencioso inseguro.
JWT_SECRET=
JWT_REFRESH_SECRET=

# Cifrado en reposo de credenciales de exchange guardadas por el usuario
KUKORA_MASTER_KEY=

# Google Sign-In (Firebase Admin) — opcional
FIREBASE_PROJECT_ID=

# ─── Cache / colas compartidas (opcional) ───────────────────────────────
# Sin esto, los stream tickets de SSE viven en memoria de proceso (válido
# para una sola instancia; necesario si escalas horizontalmente).
REDIS_URL=

# ─── Trading en vivo — flags maestros ───────────────────────────────────
LIVE_TRADING_ENABLED=false
TRADING_MODE=paper
DEMO_MODE=true
TRADE_AMOUNT_BTC=0.01
FORCE_MAKER_FEES=false

# ─── Credenciales de exchange (solo si LIVE_TRADING_ENABLED=true) ───────
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true

BYBIT_TESTNET=true

KRAKEN_SANDBOX=true
KRAKEN_SANDBOX_URL=

OKX_API_PASSPHRASE=
OKX_DEMO_TRADING=true

# Balances iniciales en modo paper/simulado
WALLET_BTC=1
WALLET_ETH=10
WALLET_XRP=1000
WALLET_USDT=10000

# Rate limiting saliente por exchange — override opcional, ver
# server/infrastructure/exchangeRateLimiter.js
# EXCHANGE_RATE_LIMIT_BINANCE=20

# ─── Riesgo / alertas ────────────────────────────────────────────────────
MAX_DAILY_LOSS_USD=500
REBALANCE_DRIFT_THRESHOLD_PCT=10
ALERT_MIN_PROFIT=0.5
ALERT_COOLDOWN_MS=300000
RISK_FREE_RATE=0.02

# ─── Notificaciones (opcional) ───────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
WEBHOOK_URL=

# ─── SSE — límites de conexión concurrente ──────────────────────────────
MAX_SSE_CLIENTS=200
MAX_ALERT_SSE_CLIENTS=200
MAX_NOTIFICATION_SSE_CLIENTS=200

# ─── Observabilidad ──────────────────────────────────────────────────────
MEMORY_WARN_MB=512
MEMORY_CRIT_MB=1024
MONTHLY_INFRA_COST_USD=

# OpenTelemetry (tracing distribuido) — opcional, off por default.
# OTEL_ENABLED=true por sí solo ya sirve para ver spans en consola.
# OTEL_EXPORTER_OTLP_ENDPOINT apunta a un collector real (Tempo/Jaeger/etc).
OTEL_ENABLED=false
OTEL_SERVICE_NAME=kukora
OTEL_EXPORTER_OTLP_ENDPOINT=

# ─── Administración / API interna ───────────────────────────────────────
ADMIN_EMAILS=
# OPERATOR_EMAILS (coma-separado, mismo patrón que ADMIN_EMAILS): otorga el
# rol 'operator' (server/infrastructure/rbac.js) — puede operar flags/jobs
# del día a día pero no el kill switch ni acciones admin-only.
OPERATOR_EMAILS=
ADMIN_TOKEN=
INTERNAL_API_KEY=

# ─── Debug ───────────────────────────────────────────────────────────────
DEBUG_KUKORA=0


# ─── Firebase (Google Sign-In) — variables de build de Vite ────────────
# Estas se hornean en el bundle durante `npm run build`, no son runtime.
# Sin ellas, el botón de Google Sign-In queda deshabilitado (no truena).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
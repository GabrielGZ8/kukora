{
  "engines": {
    "node": ">=18"
  },
  "name": "kukora",
  "version": "2.23.0",
  "description": "Kukora — Quantitative Crypto Arbitrage Intelligence Platform",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently -n SERVER,VITE -c cyan,magenta \"node server/index.js\" \"vite\"",
    "dev:watch": "concurrently -n SERVER,VITE -c cyan,magenta \"node --watch --watch-path=server server/index.js\" \"vite\"",
    "build": "vite build",
    "build:ts": "tsc",
    "start": "cross-env NODE_ENV=production node server/index.js",
    "preview": "vite preview",
    "dev:kill": "npx kill-port 5000 && npm run dev",
    "test": "vitest run",
    "test:smoke": "node tests/smoke.test.js",
    "lint": "eslint src/ server/ --ext .js,.jsx",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint:fix": "eslint src/ server/ --ext .js,.jsx --fix",
    "docker:build": "docker build -t kukora .",
    "docker:run": "docker run -p 5000:5000 --env-file .env kukora",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop ecosystem.config.js",
    "pm2:restart": "pm2 reload ecosystem.config.js",
    "pm2:logs": "pm2 logs kukora",
    "pm2:status": "pm2 status kukora",
    "audit": "npm audit --audit-level=high",
    "prepare": "husky",
    "check:ts-drift": "node scripts/checkTsBuildDrift.js",
    "check:i18n": "node scripts/checkI18nCoverage.js",
    "tape:record": "node scripts/tapeRecorder.js",
    "tape:sweep": "node scripts/experimentSweep.js"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.78.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.220.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.220.0",
    "@opentelemetry/resources": "^2.9.0",
    "@opentelemetry/sdk-metrics": "^2.9.0",
    "@opentelemetry/sdk-node": "^0.220.0",
    "@opentelemetry/sdk-trace-node": "^2.9.0",
    "@opentelemetry/semantic-conventions": "^1.43.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "cross-env": "^10.1.0",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "firebase": "^11.0.2",
    "firebase-admin": "^13.0.2",
    "helmet": "^8.2.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^7.2.0",
    "mongoose": "^8.24.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.4.1",
    "react-router-dom": "^6.21.1",
    "recharts": "^2.10.3",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/mongoose": "^5.11.97",
    "@types/node": "^22.20.0",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^4.1.9",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.1",
    "eslint-plugin-react-hooks": "^4.6.2",
    "husky": "^9.0.0",
    "jsdom": "^25.0.1",
    "lightweight-charts": "^4.1.3",
    "pm2": "^5.4.2",
    "supertest": "^7.2.2",
    "typescript": "^5.9.3",
    "vite": "^5.0.8",
    "vitest": "^4.1.9"
  },
  "license": "UNLICENSED",
  "private": true,
  "homepage": "https://github.com/GabrielGZ8/kukora",
  "repository": {
    "type": "git",
    "url": "https://github.com/GabrielGZ8/kukora.git"
  }
}

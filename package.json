{
  "engines": {
    "node": ">=18"
  },
  "name": "kukora",
  "version": "2.0.0",
  "description": "Kukora — Quantitative Crypto Intelligence OS · Hackathon Edition",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently -n SERVER,VITE -c cyan,magenta \"node server/index.js\" \"vite\"",
    "dev:watch": "concurrently -n SERVER,VITE -c cyan,magenta \"node --watch --watch-path=server server/index.js\" \"vite\"",
    "build": "vite build",
    "start": "cross-env NODE_ENV=production node server/index.js",
    "preview": "vite preview",
    "dev:kill": "npx kill-port 5000 && npm run dev"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^8.2.0",
    "lightweight-charts": "^4.1.3",
    "mongodb": "^7.2.0",
    "mongoose": "^8.3.0",
    "ws": "^8.21.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.4.1",
    "react-router-dom": "^6.21.1",
    "recharts": "^2.10.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "vite": "^5.0.8",
    "concurrently": "^8.2.2",
    "cross-env": "^10.1.0"
  }
}
